<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Izin internet untuk YouTube -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Jaga layar tetap menyala saat karaoke -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Deklarasi support Android TV -->
    <uses-feature android:name="android.software.leanback" android:required="false"/>
    <!-- Deklarasi touchscreen tidak wajib (untuk TV) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false"/>

    <application
        android:label="RaRa Cafe Karaoke"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:banner="@mipmap/ic_launcher"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="landscape">

            <!-- Intent filter untuk HP Android biasa -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Intent filter untuk Android TV (Leanback launcher) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LEANBACK_LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Flutter background service -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

    </application>

    <!-- Queries untuk koneksi ke YouTube -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>

</manifest>
